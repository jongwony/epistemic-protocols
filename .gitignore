dist/
dist-site/
node_modules/

# Anamnesis hook output — v0.4.4+ writes INDEX to ~/.claude/projects/{slug}/
# hypomnesis/{session-id}/ (outside repo). This pattern remains to ignore any
# pre-v0.4.4 residue at {cwd}/hypomnesis/ until the transitional data is
# archived or removed. Personal session content; never commit.
hypomnesis/

# audit-delta skill output — point-in-time derived view from three live sources
# (git log + gh CLI + frozen-config.md). Stateless per SKILL.md; regenerable
# any time. Baseline heavy audit (audit-YYYY-MM-DD.md) remains the sole
# authoritative historical record tracked in git.
docs/audit-delta-*.md
